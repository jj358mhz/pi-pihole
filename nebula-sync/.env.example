# nebula-sync configuration
# Copy to .env and fill in real values. Do not commit .env.

# Pi-hole endpoints with admin passwords, separated by |
# Multiple replicas separated by comma
PRIMARY=http://192.168.53.51|CHANGE_ME
REPLICAS=http://192.168.53.52|CHANGE_ME

# Sync mode: true = full teleporter import/export
FULL_SYNC=true

# Cron schedule (every minute by default)
CRON=* * * * *

# Timezone
TZ=America/Los_Angeles
